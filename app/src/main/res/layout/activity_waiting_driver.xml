<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 🗺️ MAP -->
    <fragment
        android:id="@+id/map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- 🔵 PULSE CENTER -->
    <FrameLayout
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_centerInParent="true">

        <!-- cercle 1 -->
        <View
            android:id="@+id/pulse1"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/circle_pulse" />

        <!-- cercle 2 -->
        <View
            android:id="@+id/pulse2"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/circle_pulse" />

        <!-- cercle centre -->
        <View
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_gravity="center"
            android:background="@drawable/circle_center"
            android:visibility="gone"/>

        <!-- icone localisation -->
        <ImageView
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_location"
            android:tint="@android:color/white" />

    </FrameLayout>

    <!-- 📋 bouton liste -->
    <ImageButton
        android:id="@+id/btnOrders"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_margin="26dp"
        android:background="@drawable/circle_white"
        android:src="@android:drawable/ic_menu_agenda"
        android:visibility="gone"/>

    <!-- 🔽 PANEL BAS -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="24dp"
        android:background="@android:color/white"
        android:elevation="12dp"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 🔥 SEARCHING -->
        <LinearLayout
            android:id="@+id/layoutSearching"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="12dp">

            <!-- TEXT -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recherche d’un chauffeur..."
                android:textColor="#000000"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Veuillez patienter..."
                android:textColor="#777777"
                android:textSize="14sp"/>

            <!-- 🔥 LOADING -->
            <ProgressBar
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:layout_marginTop="18dp"/>

            <!-- 🔥 CANCEL BUTTON -->
            <Button
                android:id="@+id/btnCancelSearching"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="20dp"
                android:backgroundTint="#E53935"
                android:text="ANNULER LA RECHERCHE"
                android:textColor="@android:color/white"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- 🔥 DRIVER FOUND -->
        <LinearLayout
            android:id="@+id/layoutDriver"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginBottom="20dp">

            <!-- TOP -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- PHOTO -->
                <ImageView
                    android:id="@+id/imgDriver"
                    android:layout_width="55dp"
                    android:layout_height="55dp"
                    android:background="@drawable/bg_circle_gray"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_profile"/>

                <!-- INFOS -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvDriverName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chauffeur"
                        android:textColor="#111111"
                        android:textSize="17sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvArrival"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Le chauffeur arrive dans..."
                        android:textColor="#2E7D32"
                        android:textSize="13sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvCar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text=""
                        android:textColor="#777777"
                        android:textSize="13sp"/>
                </LinearLayout>

                <!-- INFO ICON -->
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_info"/>
            </LinearLayout>

            <!-- PAYMENT -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:layout_marginTop="16dp"
                android:background="#F5F5F5"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="35dp"
                    android:layout_weight="1"
                    android:background="#4CAF50"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_money"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="Cash"
                        android:textColor="@android:color/white"
                        android:textSize="13sp"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Card"
                    android:textColor="#777777"
                    android:textSize="13sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Promo"
                    android:textColor="#777777"
                    android:textSize="13sp"/>
            </LinearLayout>

            <!-- BUTTONS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <!-- CANCEL -->
                <Button
                    android:id="@+id/btnCancel"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:backgroundTint="@android:color/holo_red_dark"
                    android:text="Annuler"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"/>

                <!-- CALL -->
                <Button
                    android:id="@+id/btnCallDriver"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:backgroundTint="#2196F3"
                    android:text="Appeler"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"/>
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</RelativeLayout>